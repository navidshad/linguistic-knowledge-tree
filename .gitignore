# Python
backend/.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.mypy_cache/

# Node / frontend
frontend/node_modules/
frontend/dist/
*.log

# Datasets (large, license-gated — never commit; Phase 5 validation data).
# Root-anchored so it does NOT match the backend/ai/klg_ai/data/ source package.
# Ignore everything under /data/ EXCEPT the small, self-collected IELTS mock-test
# transcripts (raw, committed for reproducibility); their processed outputs stay
# regenerable/ignored (pinned aggregate lives in docs/ielts-case-study/).
/data/*
!/data/ielts/
/data/ielts/processed/

# Secrets / local env (e.g. GEMINI_API_KEY for the Phase 6 chat tutor) — never commit
.env
.env.*

# Editor / OS
.DS_Store
.idea/
.vscode/

# Local tooling (machine-specific preview config + local settings)
.claude/
